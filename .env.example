# Copy this file to .env and fill in your actual values
# This file is for reference only - DO NOT commit .env with actual secrets

# MongoDB Configuration
# IMPORTANT: Each developer must use a DIFFERENT MONGO_DB_NAME to avoid sharing test data
# Example for dev: shopping_guide_dev or shopping_guide_teammate_name
# This ensures your test data doesn't mix with others
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=shopping_guide_dev

# Flask Configuration
# SECURITY: Change this to a random string for production
SECRET_KEY=dev-secret-key-change-this-in-production
